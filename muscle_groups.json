{
    "_comment": "Config for the keyword-based muscle-group parser in analyse.py. 'muscles' maps each canonical (detailed) muscle to a list of case-insensitive regex alias patterns. Patterns are matched against the whole lower-cased title with word boundaries applied by the matcher, longest-first, consuming matched spans so qualified terms (e.g. 'side delts') are not also caught by generic ones (e.g. 'delts'). 'rollup' maps each detailed muscle to its major group for the muscle_group field. 'back_returning_context' lists phrases where the word 'back' means 'returning' rather than the muscle, so it is ignored.",
    "muscles": {
        "Chest": ["chest\\w*", "pecs?", "\\bpex\\b", "pectacular", "pectennial", "pectonic", "pexecutioner", "incline dumbell", "incline dumbbell"],
        "Back": ["backs?", "b\\.a\\.c\\.k", "backtacular", "backsody", "backula", "lats?", "lat spread", "lat day"],
        "Biceps": ["bicep\\w*", "biceratops", "\\bbis\\b"],
        "Triceps": ["tricep\\w*", "trirannosaurus", "\\btris\\b", "skull crusher"],
        "Arms": ["arms?", "armtastic", "armageddon", "arm day", "arm pump", "straight arm", "\\bguns?\\b"],
        "Forearms": ["forearm\\w*"],
        "Shoulders": ["shoulder\\w*", "superbowlder", "bowlder", "delts?", "deltoids?", "\\bohp\\b", "overhead press"],
        "Side Delts": ["side delts?", "side/front delts?", "lateral delts?", "lateral raise"],
        "Rear Delts": ["rear delts?", "posterior delts?"],
        "Front Delts": ["front delts?", "anterior delts?"],
        "Traps": ["traps?", "trapezius"],
        "Legs": ["legs?", "leg day", "leg press", "leg veins?", "lower body", "smith squats?", "squat\\w*"],
        "Quads": ["quad\\w*", "quadzkaban"],
        "Hamstrings": ["hamstring\\w*", "\\bhams?\\b", "hamathon", "ham day", "leg curls?"],
        "Glutes": ["glute\\w*"],
        "Calves": ["calves", "\\bcalf\\b", "\\bcalve\\b", "calf raise"],
        "Adductors": ["adductors?", "abductors?"],
        "Abs": ["\\babs?\\b", "ab day", "core day"],
        "Cardio": ["cardio\\w*", "stairmaster", "treadmill", "incline walk", "\\bbike\\b", "seated bike"]
    },
    "rollup": {
